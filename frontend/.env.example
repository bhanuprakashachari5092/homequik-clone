# Vercel Deployment Environment Variables Reference
# Copy these keys into your Vercel Project Settings -> Environment Variables

# Email Automation Password (16-digit App Password from Google)
EMAIL_PASSWORD=your_16_digit_app_password

# Add any Firebase config keys here if you move them out of hardcoded config later

VITE_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=YOUR_UPLOAD_PRESET
VITE_GOOGLE_SHEETS_WEBHOOK_URL=YOUR_WEBHOOK_URL
